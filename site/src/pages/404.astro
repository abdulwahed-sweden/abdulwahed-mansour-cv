---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
  keywords="404, not found"
>
  <section class="max-w-lg mx-auto px-5 py-32 text-center animate-in">
    <div class="mono text-6xl font-bold mb-4" style="color: var(--accent); opacity: 0.85;">404</div>
    <h1 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">
      Page not found
    </h1>
    <p class="text-[15px] mb-8" style="color: var(--text-secondary);">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex justify-center gap-2.5">
      <a href="/" class="btn btn-primary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Go Home
      </a>
      <a href="mailto:abdulwahed.sweden@gmail.com" class="btn btn-secondary">Contact</a>
    </div>
  </section>
</BaseLayout>
