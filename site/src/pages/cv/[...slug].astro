---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const cvs = await getCollection("cvs");
  return cvs.map((cv) => ({
    params: { slug: cv.data.slug },
    props: { cv },
  }));
}

const { cv } = Astro.props;
const { Content } = await render(cv);

const allCvs = await getCollection("cvs");
const sorted = allCvs.sort((a, b) => a.data.order - b.data.order);
const currentIndex = sorted.findIndex((c) => c.data.slug === cv.data.slug);
const prevCv = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextCv = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const keywordList = cv.data.keywords.split(", ");
---

<BaseLayout
  title={cv.data.title}
  description={cv.data.description}
  keywords={cv.data.keywords}
  slug={cv.data.slug}
  currentSlug={cv.data.slug}
>
  <div class="max-w-3xl mx-auto px-6 py-10 sm:py-14">

    <!-- Breadcrumb -->
    <nav class="text-xs text-text-muted mb-8 animate-in">
      <a href="/" class="hover:text-text-primary transition-colors">Home</a>
      <span class="mx-1.5">/</span>
      <span class="text-text-secondary">{cv.data.short}</span>
    </nav>

    <!-- ── Header ── -->
    <header class="mb-10 animate-in" style="animation-delay: 0.05s">
      <h1 class="font-serif text-3xl sm:text-4xl font-bold text-text-primary tracking-tight leading-tight mb-2">
        Abdulwahed Mansour
      </h1>
      <p class="text-lg text-text-secondary font-medium mb-4">
        {cv.data.title}
      </p>

      <!-- Contact -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-text-muted mb-6">
        <span>Stockholm, Sweden</span>
        <span class="hidden sm:inline text-border-light">|</span>
        <a href="mailto:abdulwahed.sweden@gmail.com" class="text-text-primary underline underline-offset-3 decoration-border-light hover:decoration-text-primary transition-colors">abdulwahed.sweden@gmail.com</a>
        <span class="hidden sm:inline text-border-light">|</span>
        <a href="https://linkedin.com/in/abdulwahed-mansour" target="_blank" rel="noopener" class="text-text-primary underline underline-offset-3 decoration-border-light hover:decoration-text-primary transition-colors">LinkedIn</a>
        <span class="hidden sm:inline text-border-light">|</span>
        <a href="https://github.com/abdulwahed-sweden" target="_blank" rel="noopener" class="text-text-primary underline underline-offset-3 decoration-border-light hover:decoration-text-primary transition-colors">GitHub</a>
      </div>

      <!-- Keywords -->
      <div class="flex flex-wrap gap-2">
        {keywordList.map((kw: string) => (
          <span class="text-xs text-text-muted bg-surface-2 px-2.5 py-1 rounded">
            {kw}
          </span>
        ))}
      </div>

      <!-- Actions -->
      <div class="no-print flex items-center gap-3 mt-6 pt-6 border-t border-border">
        <button
          onclick="window.print()"
          class="text-xs text-text-muted hover:text-text-primary border border-border px-3 py-1.5 rounded transition-colors"
        >
          Print / Save PDF
        </button>
        <a
          href="mailto:abdulwahed.sweden@gmail.com"
          class="text-xs font-semibold text-surface-0 bg-text-primary px-4 py-1.5 rounded hover:bg-text-secondary transition-colors"
        >
          Contact me
        </a>
      </div>
    </header>

    <hr class="border-t border-border mb-10" />

    <!-- ── CV Content ── -->
    <article class="cv-prose animate-in" style="animation-delay: 0.1s">
      <Content />
    </article>

    <!-- ── Prev/Next ── -->
    <nav class="no-print mt-16 pt-8 border-t border-border flex justify-between items-start gap-4 animate-in" style="animation-delay: 0.15s">
      {prevCv ? (
        <a href={`/cv/${prevCv.data.slug}/`} class="group text-left">
          <div class="text-xs text-text-muted mb-1">&larr; Previous</div>
          <div class="text-sm font-medium text-text-secondary group-hover:text-text-primary transition-colors">
            {prevCv.data.title}
          </div>
        </a>
      ) : <div />}
      {nextCv ? (
        <a href={`/cv/${nextCv.data.slug}/`} class="group text-right">
          <div class="text-xs text-text-muted mb-1">Next &rarr;</div>
          <div class="text-sm font-medium text-text-secondary group-hover:text-text-primary transition-colors">
            {nextCv.data.title}
          </div>
        </a>
      ) : <div />}
    </nav>
  </div>
</BaseLayout>
