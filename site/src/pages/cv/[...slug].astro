---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const cvs = await getCollection("cvs");
  return cvs.map((cv) => ({
    params: { slug: cv.data.slug },
    props: { cv },
  }));
}

const { cv } = Astro.props;
const { Content } = await render(cv);

const allCvs = await getCollection("cvs");
const sorted = allCvs.sort((a, b) => a.data.order - b.data.order);
const currentIndex = sorted.findIndex((c) => c.data.slug === cv.data.slug);
const prevCv = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextCv = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const keywordList = cv.data.keywords.split(", ");
const wordCount = cv.body ? cv.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.round(wordCount / 200));
---

<BaseLayout
  title={cv.data.title}
  description={cv.data.description}
  keywords={cv.data.keywords}
  slug={cv.data.slug}
  currentSlug={cv.data.slug}
>
  <div class="max-w-3xl mx-auto px-5 py-10 sm:py-16">

    <!-- Breadcrumb -->
    <nav class="no-print flex items-center gap-2 text-[13px] mb-8 animate-in" style="color: var(--text-tertiary);">
      <a href="/" class="transition-colors hover:text-[var(--text-primary)]" style="color: var(--text-secondary);">Home</a>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <span style="color: var(--text-secondary);">{cv.data.short}</span>
    </nav>

    <!-- Header -->
    <div class="card-static print-header p-6 sm:p-8 mb-10 animate-in" style="animation-delay: 0.04s">
      <div class="flex items-center justify-between mb-6">
        <div class="w-10 h-[2px] rounded-full" style="background: var(--accent);"></div>
        <span class="no-print text-[13px] mono" style="color: var(--text-tertiary);">{readingTime} min read</span>
      </div>

      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight mb-2" style="color: var(--text-primary); letter-spacing: -0.03em;">
        Abdulwahed Mansour
      </h1>
      <p class="text-base sm:text-lg font-semibold mb-5" style="color: var(--accent);">
        {cv.data.title}
      </p>

      <!-- Contact -->
      <div class="print-contact text-sm mb-5" style="color: var(--text-secondary);">
        <div class="flex flex-wrap items-center gap-x-2 gap-y-1.5">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 no-print flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Stockholm, Sweden
          </span>
          <span class="hidden sm:inline" style="color: var(--text-tertiary);">/</span>
          <a href="mailto:abdulwahed.sweden@gmail.com" class="transition-colors hover:text-[var(--accent)]" style="color: var(--text-primary);">abdulwahed.sweden@gmail.com</a>
          <span class="hidden sm:inline" style="color: var(--text-tertiary);">/</span>
          <a href="https://linkedin.com/in/abdulwahed-mansour" target="_blank" rel="noopener" class="transition-colors hover:text-[var(--accent)]" style="color: var(--text-primary);">LinkedIn</a>
          <span class="hidden sm:inline" style="color: var(--text-tertiary);">/</span>
          <a href="https://github.com/abdulwahed-sweden" target="_blank" rel="noopener" class="transition-colors hover:text-[var(--accent)]" style="color: var(--text-primary);">GitHub</a>
        </div>
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-1.5 mb-4">
        {cv.data.tags.map((tag: string) => (
          <span class="tag tag-accent">{tag}</span>
        ))}
      </div>

      <!-- Keywords -->
      <div class="print-keywords flex flex-wrap gap-1.5 mb-5">
        {keywordList.map((kw: string) => (
          <span class="tag">{kw}</span>
        ))}
      </div>

      <!-- Actions -->
      <div class="no-print flex items-center gap-2 pt-5" style="border-top: 1px solid var(--border);">
        <button onclick="window.print()" class="btn btn-ghost" style="font-size: 13px; padding: 7px 12px;">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
          Print / PDF
        </button>
        <a href="mailto:abdulwahed.sweden@gmail.com" class="btn btn-primary" style="font-size: 13px; padding: 7px 12px;">
          Contact me
        </a>
        <div class="flex-1"></div>
        {prevCv && (
          <a href={`/cv/${prevCv.data.slug}/`} class="btn btn-secondary" style="font-size: 13px; padding: 6px 10px;" title={prevCv.data.title}>
            &larr; Prev
          </a>
        )}
        {nextCv && (
          <a href={`/cv/${nextCv.data.slug}/`} class="btn btn-secondary" style="font-size: 13px; padding: 6px 10px;" title={nextCv.data.title}>
            Next &rarr;
          </a>
        )}
      </div>
    </div>

    <!-- Private repos notice -->
    <div class="no-print flex items-start gap-3 p-4 rounded-xl mb-10 animate-in" style="animation-delay: 0.06s; background: var(--notice-wash); border: 1px solid var(--notice-border);">
      <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: var(--notice-icon);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      <div>
        <p class="text-sm font-bold mb-0.5" style="color: var(--notice-text);">Private Repositories</p>
        <p class="text-[13px] leading-relaxed" style="color: var(--notice-muted);">Some projects referenced below are hosted in private GitHub repositories due to sensitivity. Full source access is available upon request for interviews and due diligence.</p>
      </div>
    </div>

    <!-- Content -->
    <article class="cv-prose animate-in" style="animation-delay: 0.08s">
      <Content />
    </article>

    <!-- Prev/Next -->
    <nav class="no-print mt-16 pt-8 grid grid-cols-2 gap-3 animate-in" style="border-top: 1px solid var(--border); animation-delay: 0.12s">
      {prevCv ? (
        <a href={`/cv/${prevCv.data.slug}/`} class="card group p-4 text-left no-underline">
          <div class="label mb-1.5">&larr; Previous</div>
          <div class="text-sm font-semibold leading-snug" style="color: var(--text-primary);">
            {prevCv.data.short}
          </div>
        </a>
      ) : <div />}
      {nextCv ? (
        <a href={`/cv/${nextCv.data.slug}/`} class="card group p-4 text-right no-underline ml-auto w-full">
          <div class="label mb-1.5">Next &rarr;</div>
          <div class="text-sm font-semibold leading-snug" style="color: var(--text-primary);">
            {nextCv.data.short}
          </div>
        </a>
      ) : <div />}
    </nav>
  </div>

  <!-- Back to top -->
  <button
    id="back-to-top"
    class="no-print fixed bottom-6 right-6 w-9 h-9 rounded-lg flex items-center justify-center opacity-0 pointer-events-none z-40"
    style="background: var(--accent); color: white; box-shadow: var(--shadow-md);"
    aria-label="Back to top"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
  </button>

  <script is:inline>
    var topBtn = document.getElementById("back-to-top");
    window.addEventListener("scroll", function() {
      if (!topBtn) return;
      if (window.scrollY > 400) {
        topBtn.style.opacity = "1";
        topBtn.style.pointerEvents = "auto";
      } else {
        topBtn.style.opacity = "0";
        topBtn.style.pointerEvents = "none";
      }
    }, { passive: true });
    topBtn?.addEventListener("click", function() {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  </script>
</BaseLayout>
