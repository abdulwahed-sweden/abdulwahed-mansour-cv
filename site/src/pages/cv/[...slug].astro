---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const cvs = await getCollection("cvs");
  return cvs.map((cv) => ({
    params: { slug: cv.data.slug },
    props: { cv },
  }));
}

const { cv } = Astro.props;
const { Content } = await render(cv);

const allCvs = await getCollection("cvs");
const sorted = allCvs.sort((a, b) => a.data.order - b.data.order);
const currentIndex = sorted.findIndex((c) => c.data.slug === cv.data.slug);
const prevCv = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextCv = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const keywordList = cv.data.keywords.split(", ");
const accentColor = cv.data.accent || '#3b82f6';
---

<BaseLayout
  title={cv.data.title}
  description={cv.data.description}
  keywords={cv.data.keywords}
  slug={cv.data.slug}
  currentSlug={cv.data.slug}
>
  <div class="max-w-3xl mx-auto px-6 py-10 sm:py-14">

    <!-- Breadcrumb (hidden in print) -->
    <nav class="no-print flex items-center gap-2 text-xs mb-8 animate-in" style="color: var(--color-text-muted);">
      <a href="/" class="transition-colors hover:text-[var(--color-text-primary)]">Home</a>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <span style="color: var(--color-text-secondary);">{cv.data.short}</span>
    </nav>

    <!-- Header card -->
    <div class="card-static print-header p-6 sm:p-8 mb-10 animate-in" style="animation-delay: 0.05s">
      <!-- Accent bar -->
      <div class="print-accent-bar h-1 w-16 rounded-full mb-6" style={`background: linear-gradient(90deg, ${accentColor}, ${accentColor}88);`}></div>

      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight mb-2" style="color: var(--color-text-primary); letter-spacing: -0.02em;">
        Abdulwahed Mansour
      </h1>
      <p class="text-lg font-semibold mb-5" style={`color: ${accentColor};`}>
        {cv.data.title}
      </p>

      <!-- Contact -->
      <div class="print-contact flex flex-wrap items-center gap-x-4 gap-y-1 text-sm mb-6" style="color: var(--color-text-muted);">
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 no-print" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Stockholm, Sweden
        </span>
        <span style="color: var(--border-subtle);">|</span>
        <a href="mailto:abdulwahed.sweden@gmail.com" class="transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-primary);">abdulwahed.sweden@gmail.com</a>
        <span class="hidden sm:inline" style="color: var(--border-subtle);">|</span>
        <a href="https://linkedin.com/in/abdulwahed-mansour" target="_blank" rel="noopener" class="transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-primary);">LinkedIn</a>
        <span class="hidden sm:inline" style="color: var(--border-subtle);">|</span>
        <a href="https://github.com/abdulwahed-sweden" target="_blank" rel="noopener" class="transition-colors hover:text-[var(--color-primary)]" style="color: var(--color-text-primary);">GitHub</a>
      </div>

      <!-- Keywords -->
      <div class="print-keywords flex flex-wrap gap-1.5 mb-6">
        {keywordList.map((kw: string) => (
          <span class="badge badge-muted" style="font-size: 12px; padding: 3px 8px;">
            {kw}
          </span>
        ))}
      </div>

      <!-- Actions (hidden in print) -->
      <div class="no-print flex items-center gap-3 pt-5" style="border-top: 1px solid var(--border-subtle);">
        <button
          onclick="window.print()"
          class="button button-ghost"
          style="font-size: 13px; padding: 8px 16px;"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
          Print / Save PDF
        </button>
        <a
          href="mailto:abdulwahed.sweden@gmail.com"
          class="button button-primary"
          style="font-size: 13px; padding: 8px 16px;"
        >
          Contact me
        </a>
      </div>
    </div>

    <!-- CV Content -->
    <article class="cv-prose animate-in" style="animation-delay: 0.1s">
      <Content />
    </article>

    <!-- Prev/Next (hidden in print) -->
    <nav class="no-print mt-16 pt-8 flex justify-between items-start gap-4 animate-in" style="border-top: 1px solid var(--border-subtle); animation-delay: 0.15s">
      {prevCv ? (
        <a href={`/cv/${prevCv.data.slug}/`} class="card hover-lift group p-4 text-left no-underline max-w-[45%]">
          <div class="text-xs mb-1 font-semibold" style="color: var(--color-text-muted);">&larr; Previous</div>
          <div class="text-sm font-bold" style="color: var(--color-text-primary);">
            {prevCv.data.title}
          </div>
        </a>
      ) : <div />}
      {nextCv ? (
        <a href={`/cv/${nextCv.data.slug}/`} class="card hover-lift group p-4 text-right no-underline max-w-[45%] ml-auto">
          <div class="text-xs mb-1 font-semibold" style="color: var(--color-text-muted);">Next &rarr;</div>
          <div class="text-sm font-bold" style="color: var(--color-text-primary);">
            {nextCv.data.title}
          </div>
        </a>
      ) : <div />}
    </nav>
  </div>
</BaseLayout>
