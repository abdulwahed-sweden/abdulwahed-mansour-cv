---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allCvs = await getCollection("cvs");
const sorted = allCvs.sort((a, b) => a.data.order - b.data.order);

const stats = [
  { value: "21+", label: "Repositories" },
  { value: "208K+", label: "Lines of Code" },
  { value: "5,700+", label: "Tests Written" },
  { value: "$98.6M", label: "Exposure Found" },
];

const expertise = [
  { title: "Security", items: ["Smart Contract Auditing", "Penetration Testing", "Blockchain Forensics", "Vulnerability Research"] },
  { title: "Systems", items: ["Rust & Async Programming", "Python Backend (FastAPI/Django)", "DevOps & CI/CD", "Cloud Infrastructure"] },
  { title: "Blockchain", items: ["DeFi Protocol Design", "Islamic Finance Protocols", "ERC-4337 / ERC-4626", "Solidity & Foundry"] },
  { title: "AI & Full-Stack", items: ["LLM Integration (MCP)", "Next.js / Vue / React", "AI Pipeline Architecture", "Multi-provider Backends"] },
];
---

<BaseLayout
  title="Portfolio"
  description="Abdulwahed Mansour — Smart contract security researcher, Rust systems engineer, and protocol architect based in Stockholm. 21+ repositories, 208,000+ lines of code, 5,700+ tests."
  keywords="Abdulwahed Mansour, Security Researcher, Rust Engineer, Smart Contract Auditor, DeFi, Blockchain, Stockholm, Sweden"
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-5 pt-24 sm:pt-32 pb-6 animate-in">
    <div class="max-w-2xl">
      <div class="label mb-4">Stockholm, Sweden</div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] mb-4" style="color: var(--text-primary); letter-spacing: -0.035em;">
        Abdulwahed<br/>
        <span class="gradient-text">Mansour</span>
      </h1>
      <p class="text-base sm:text-lg leading-relaxed mb-8" style="color: var(--text-secondary);">
        Security researcher, systems engineer, and protocol architect building secure infrastructure for the decentralized web.
      </p>

      <div class="flex flex-wrap gap-2.5">
        <a href="mailto:abdulwahed.sweden@gmail.com" class="btn btn-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Get in Touch
        </a>
        <a href="https://github.com/abdulwahed-sweden" target="_blank" rel="noopener" class="btn btn-secondary">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="https://linkedin.com/in/abdulwahed-mansour" target="_blank" rel="noopener" class="btn btn-ghost">
          LinkedIn
        </a>
        <a href="/cover-letter/" class="btn btn-ghost">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Cover Letter
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="max-w-5xl mx-auto px-5 py-10 animate-in" style="animation-delay: 0.06s">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {stats.map((stat) => (
        <div class="card-static p-5 text-center">
          <div class="text-2xl sm:text-3xl font-bold mono leading-tight" style="color: var(--text-primary);">{stat.value}</div>
          <div class="mt-1.5 label">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Expertise -->
  <section class="max-w-5xl mx-auto px-5 py-10 animate-in" style="animation-delay: 0.1s">
    <h2 class="text-xl font-bold mb-5" style="color: var(--text-primary);">Core Expertise</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
      {expertise.map((area) => (
        <div class="card-static p-5">
          <div class="w-8 h-[2px] rounded-full mb-4" style="background: var(--accent);"></div>
          <h3 class="text-base font-bold mb-3" style="color: var(--text-primary);">{area.title}</h3>
          <ul class="space-y-2">
            {area.items.map((item) => (
              <li class="text-sm flex items-start gap-2" style="color: var(--text-secondary);">
                <span class="mt-[7px] w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: var(--accent); opacity: 0.85;"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- CV List -->
  <section class="max-w-5xl mx-auto px-5 py-10">
    <div class="flex items-center gap-3 mb-5 animate-in" style="animation-delay: 0.14s">
      <h2 class="text-xl font-bold" style="color: var(--text-primary);">Professional Profiles</h2>
      <span class="tag tag-accent mono">{sorted.length}</span>
    </div>

    <div class="grid gap-2">
      {sorted.map((cv, i) => (
        <a
          href={`/cv/${cv.data.slug}/`}
          class="card group flex items-start gap-4 p-4 sm:p-5 no-underline animate-in"
          style={`animation-delay: ${0.16 + 0.02 * i}s`}
        >
          <div class="flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center text-[13px] font-bold mono text-white" style="background: var(--accent);">
            {String(cv.data.order).padStart(2, "0")}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <span class="text-[15px] font-semibold block leading-snug" style="color: var(--text-primary);">
                  {cv.data.title}
                </span>
                <span class="text-sm leading-relaxed block mt-1" style="color: var(--text-secondary);">
                  {cv.data.description}
                </span>
              </div>
              <svg class="w-4 h-4 flex-shrink-0 mt-0.5 opacity-0 group-hover:opacity-100 transition-opacity" style="color: var(--accent);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
            <div class="flex flex-wrap gap-1.5 mt-2.5">
              {cv.data.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-5 py-16 animate-in" style="animation-delay: 0.4s">
    <div class="card-static p-8 sm:p-12 text-center" style="background: var(--accent-wash); border-color: var(--accent-border);">
      <p class="text-xl font-bold mb-2" style="color: var(--text-primary);">Available for opportunities</p>
      <p class="text-[15px] mb-6 max-w-md mx-auto" style="color: var(--text-secondary);">
        Full-time positions, contract work, and security audits in Stockholm and remote.
      </p>
      <div class="flex flex-wrap justify-center gap-2.5">
        <a href="mailto:abdulwahed.sweden@gmail.com" class="btn btn-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Get in Touch
        </a>
        <a href="https://linkedin.com/in/abdulwahed-mansour" target="_blank" rel="noopener" class="btn btn-secondary">
          LinkedIn
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
