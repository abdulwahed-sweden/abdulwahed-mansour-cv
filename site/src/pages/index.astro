---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allCvs = await getCollection("cvs");
const sorted = allCvs.sort((a, b) => a.data.order - b.data.order);

const stats = [
  { label: "Repositories", value: "21+" },
  { label: "Lines of Code", value: "208K+" },
  { label: "Tests Written", value: "5,700+" },
  { label: "Vulnerability Exposure", value: "$98.6M" },
];
---

<BaseLayout
  title="Portfolio"
  description="Abdulwahed Mansour — Smart contract security researcher, Rust systems engineer, and protocol architect based in Stockholm. 21+ repositories, 208,000+ lines of code, 5,700+ tests."
  keywords="Abdulwahed Mansour, Security Researcher, Rust Engineer, Smart Contract Auditor, DeFi, Blockchain, Stockholm, Sweden"
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Grid background -->
    <div class="absolute inset-0 grid-bg"></div>
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-surface-0 via-transparent to-surface-0"></div>

    <div class="relative max-w-4xl mx-auto px-6 pt-24 pb-16 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surface-2 border border-border text-xs font-mono text-text-muted mb-8 animate-in">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        Open to opportunities in Stockholm
      </div>

      <!-- Name -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-text-primary mb-4 animate-in" style="animation-delay: 0.1s">
        Abdulwahed <span class="text-accent">Mansour</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto mb-6 animate-in" style="animation-delay: 0.2s">
        Security Researcher · Rust Systems Engineer · Protocol Architect
      </p>

      <!-- One-liner -->
      <p class="text-sm text-text-muted max-w-xl mx-auto mb-10 animate-in" style="animation-delay: 0.3s">
        I find what static analyzers miss. Building invariant proofs, exploit simulators,
        and high-performance forensics tools — from Stockholm.
      </p>

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-2xl mx-auto animate-in" style="animation-delay: 0.4s">
        {stats.map((s) => (
          <div class="bg-surface-1 border border-border rounded-xl px-4 py-3">
            <div class="text-xl sm:text-2xl font-bold font-mono text-text-primary">{s.value}</div>
            <div class="text-xs text-text-muted mt-0.5">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CV Grid -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="flex items-center gap-3 mb-8">
      <h2 class="text-sm font-semibold text-text-muted uppercase tracking-widest">Professional Profiles</h2>
      <div class="flex-1 h-px bg-border"></div>
      <span class="text-xs font-mono text-text-muted">{sorted.length} variants</span>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      {sorted.map((cv, i) => (
        <a
          href={`/cv/${cv.data.slug}/`}
          class="group relative bg-surface-1 border border-border rounded-xl p-5 hover:border-border-light hover:bg-surface-2 transition-all duration-200 animate-in"
          style={`animation-delay: ${0.05 * i}s`}
        >
          <!-- Accent line -->
          <div
            class="absolute top-0 left-6 right-6 h-px opacity-0 group-hover:opacity-100 transition-opacity"
            style={`background: ${cv.data.accent}`}
          />

          <div class="flex items-start gap-4">
            <!-- Number -->
            <div
              class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center text-sm font-bold font-mono transition-colors"
              style={`background: ${cv.data.accent}15; color: ${cv.data.accent}`}
            >
              {String(cv.data.order).padStart(2, "0")}
            </div>

            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-semibold text-text-primary group-hover:text-white transition-colors mb-1 truncate">
                {cv.data.title}
              </h3>
              <p class="text-xs text-text-muted line-clamp-2 leading-relaxed">
                {cv.data.description}
              </p>

              <!-- Keywords -->
              <div class="flex flex-wrap gap-1.5 mt-3">
                {cv.data.keywords.split(", ").slice(0, 5).map((kw: string) => (
                  <span class="px-2 py-0.5 text-[10px] font-mono rounded-md bg-surface-3 text-text-muted">
                    {kw}
                  </span>
                ))}
              </div>
            </div>

            <!-- Arrow -->
            <svg
              class="w-4 h-4 text-text-muted group-hover:text-text-secondary group-hover:translate-x-0.5 transition-all flex-shrink-0 mt-1"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="max-w-4xl mx-auto px-6 pb-16">
    <div class="bg-surface-1 border border-border rounded-xl p-8 text-center">
      <h2 class="text-lg font-semibold text-text-primary mb-2">Let's work together</h2>
      <p class="text-sm text-text-muted mb-6">Available for full-time positions, contract work, and security audits</p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="mailto:abdulwahed.sweden@gmail.com"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-surface-0 text-sm font-semibold rounded-lg hover:opacity-90 transition-opacity"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Get in touch
        </a>
        <a
          href="https://github.com/abdulwahed-sweden"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-surface-2 border border-border text-text-secondary text-sm font-medium rounded-lg hover:text-text-primary hover:border-border-light transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
          View GitHub
        </a>
        <a
          href="https://linkedin.com/in/abdulwahed-mansour"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-surface-2 border border-border text-text-secondary text-sm font-medium rounded-lg hover:text-text-primary hover:border-border-light transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
