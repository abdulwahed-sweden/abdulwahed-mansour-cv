---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allCvs = await getCollection("cvs");
const sorted = allCvs.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Portfolio"
  description="Abdulwahed Mansour — Smart contract security researcher, Rust systems engineer, and protocol architect based in Stockholm. 21+ repositories, 208,000+ lines of code, 5,700+ tests."
  keywords="Abdulwahed Mansour, Security Researcher, Rust Engineer, Smart Contract Auditor, DeFi, Blockchain, Stockholm, Sweden"
>
  <!-- Hero -->
  <section class="max-w-3xl mx-auto px-6 pt-20 sm:pt-28 pb-16 text-center animate-in">
    <h1 class="font-serif text-4xl sm:text-5xl font-bold text-text-primary tracking-tight leading-tight mb-4">
      Abdulwahed Mansour
    </h1>
    <p class="text-lg text-text-muted mb-3">
      Security Researcher &middot; Systems Engineer &middot; Protocol Architect
    </p>
    <p class="text-sm text-text-muted mb-8">
      Stockholm, Sweden
    </p>

    <!-- Stats row -->
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-text-muted mb-10">
      <span><strong class="text-text-primary font-semibold">21+</strong> repositories</span>
      <span><strong class="text-text-primary font-semibold">208K+</strong> lines of code</span>
      <span><strong class="text-text-primary font-semibold">5,700+</strong> tests</span>
      <span><strong class="text-text-primary font-semibold">$98.6M</strong> exposure found</span>
    </div>

    <!-- Contact links -->
    <div class="flex flex-wrap justify-center gap-4 text-sm">
      <a href="mailto:abdulwahed.sweden@gmail.com" class="text-text-primary underline underline-offset-4 decoration-border-light hover:decoration-text-primary transition-colors">Email</a>
      <a href="https://github.com/abdulwahed-sweden" target="_blank" rel="noopener" class="text-text-primary underline underline-offset-4 decoration-border-light hover:decoration-text-primary transition-colors">GitHub</a>
      <a href="https://linkedin.com/in/abdulwahed-mansour" target="_blank" rel="noopener" class="text-text-primary underline underline-offset-4 decoration-border-light hover:decoration-text-primary transition-colors">LinkedIn</a>
    </div>
  </section>

  <hr class="max-w-3xl mx-auto border-t border-border" />

  <!-- CV List -->
  <section class="max-w-3xl mx-auto px-6 py-14">
    <h2 class="font-serif text-xl font-bold italic text-text-primary mb-8">Professional Profiles</h2>

    <div class="space-y-0">
      {sorted.map((cv, i) => (
        <a
          href={`/cv/${cv.data.slug}/`}
          class="group flex items-baseline gap-4 py-4 border-b border-border hover:bg-surface-2/50 transition-colors -mx-4 px-4 rounded animate-in"
          style={`animation-delay: ${0.03 * i}s`}
        >
          <span class="text-xs font-mono text-text-muted w-6 flex-shrink-0">
            {String(cv.data.order).padStart(2, "0")}
          </span>
          <span class="flex-1">
            <span class="text-base font-semibold text-text-primary group-hover:underline underline-offset-4">
              {cv.data.title}
            </span>
            <span class="block text-sm text-text-muted mt-0.5 leading-relaxed">
              {cv.data.description}
            </span>
          </span>
          <span class="text-text-muted group-hover:text-text-primary transition-colors flex-shrink-0">&rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <hr class="max-w-3xl mx-auto border-t border-border" />

  <!-- Bottom CTA -->
  <section class="max-w-3xl mx-auto px-6 py-14 text-center">
    <p class="font-serif text-lg italic text-text-muted mb-4">
      Available for full-time positions, contract work, and security audits.
    </p>
    <a
      href="mailto:abdulwahed.sweden@gmail.com"
      class="inline-block text-sm font-semibold text-text-primary border border-text-primary px-6 py-2.5 rounded hover:bg-text-primary hover:text-surface-0 transition-colors"
    >
      Get in touch
    </a>
  </section>
</BaseLayout>
