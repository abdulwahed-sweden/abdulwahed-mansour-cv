---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allCvs = await getCollection("cvs");
const sorted = allCvs.sort((a, b) => a.data.order - b.data.order);

const stats = [
  { value: "21+", label: "Repositories", gradient: "var(--gradient-primary)" },
  { value: "208K+", label: "Lines of Code", gradient: "var(--gradient-accent)" },
  { value: "5,700+", label: "Tests Written", gradient: "var(--gradient-success)" },
  { value: "$98.6M", label: "Exposure Found", gradient: "var(--gradient-danger)" },
];
---

<BaseLayout
  title="Portfolio"
  description="Abdulwahed Mansour — Smart contract security researcher, Rust systems engineer, and protocol architect based in Stockholm. 21+ repositories, 208,000+ lines of code, 5,700+ tests."
  keywords="Abdulwahed Mansour, Security Researcher, Rust Engineer, Smart Contract Auditor, DeFi, Blockchain, Stockholm, Sweden"
>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-20 sm:pt-28 pb-8 animate-in">
    <div class="hero-gradient p-8 sm:p-12 text-center">
      <div class="label mb-4">Stockholm, Sweden</div>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-tight mb-4" style="color: var(--color-text-primary); letter-spacing: -0.02em;">
        Abdulwahed Mansour
      </h1>
      <p class="text-lg mb-8" style="color: var(--color-text-muted);">
        Security Researcher &middot; Systems Engineer &middot; Protocol Architect
      </p>

      <!-- Contact links -->
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="mailto:abdulwahed.sweden@gmail.com"
          class="button button-primary"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Get in Touch
        </a>
        <a
          href="https://github.com/abdulwahed-sweden"
          target="_blank"
          rel="noopener"
          class="button button-outline"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/abdulwahed-mansour"
          target="_blank"
          rel="noopener"
          class="button button-ghost"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="max-w-4xl mx-auto px-6 py-8 animate-in" style="animation-delay: 0.05s">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {stats.map((stat) => (
        <div class="stat-tile text-center">
          <div class="icon-tile mx-auto mb-3" style={`background: ${stat.gradient};`}>
            <span class="text-sm font-bold text-white">#</span>
          </div>
          <div class="text-2xl font-bold font-mono" style="color: var(--color-text-primary);">{stat.value}</div>
          <div class="text-xs mt-1" style="color: var(--color-text-muted); font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase;">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- CV List -->
  <section class="max-w-4xl mx-auto px-6 py-10">
    <div class="flex items-center gap-3 mb-8 animate-in" style="animation-delay: 0.1s">
      <h2 class="text-xl font-bold" style="color: var(--color-text-primary); letter-spacing: -0.02em;">Professional Profiles</h2>
      <span class="badge badge-primary">{sorted.length} CVs</span>
    </div>

    <div class="grid gap-3">
      {sorted.map((cv, i) => (
        <a
          href={`/cv/${cv.data.slug}/`}
          class="card hover-lift group flex items-start gap-4 p-5 no-underline animate-in"
          style={`animation-delay: ${0.12 + 0.03 * i}s`}
        >
          <div
            class="icon-tile flex-shrink-0 mt-0.5"
            style={`background: linear-gradient(135deg, ${cv.data.accent || '#3b82f6'}, ${cv.data.accent ? cv.data.accent + 'cc' : '#1d4ed8'});`}
          >
            <span class="text-sm font-bold text-white">{String(cv.data.order).padStart(2, "0")}</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-base font-bold" style="color: var(--color-text-primary);">
                {cv.data.title}
              </span>
            </div>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
              {cv.data.description}
            </p>
          </div>
          <svg class="w-5 h-5 flex-shrink-0 mt-1 opacity-0 group-hover:opacity-100 transition-opacity" style="color: var(--color-primary);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ))}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="max-w-4xl mx-auto px-6 py-14 text-center animate-in" style="animation-delay: 0.4s">
    <div class="glass-card p-8 sm:p-10">
      <p class="text-lg font-semibold mb-2" style="color: var(--color-text-primary);">
        Available for opportunities
      </p>
      <p class="text-sm mb-6" style="color: var(--color-text-muted);">
        Full-time positions, contract work, and security audits.
      </p>
      <a href="mailto:abdulwahed.sweden@gmail.com" class="button button-primary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
