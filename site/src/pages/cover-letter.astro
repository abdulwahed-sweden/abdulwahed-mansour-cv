---
import BaseLayout from "../layouts/BaseLayout.astro";
import CoverLetterGenerator from "../components/CoverLetterGenerator.jsx";
---

<BaseLayout
  title="Cover Letter Generator"
  description="Generate tailored cover letters from 10 professional profiles and role templates."
  keywords="Cover Letter, Generator, Abdulwahed Mansour, Security Researcher, Rust Engineer, Stockholm"
>
  <div class="max-w-5xl mx-auto px-5 py-10 sm:py-16">
    <nav class="no-print flex items-center gap-2 text-[13px] mb-8 animate-in" style="color: var(--text-tertiary);">
      <a href="/" class="transition-colors hover:text-[var(--text-primary)]" style="color: var(--text-secondary);">Home</a>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <span style="color: var(--text-secondary);">Cover Letter</span>
    </nav>

    <CoverLetterGenerator client:load />
  </div>
</BaseLayout>
