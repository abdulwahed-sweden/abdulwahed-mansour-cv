---
import { getCollection } from "astro:content";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;
const allCvs = await getCollection("cvs");
const sorted = allCvs.sort((a, b) => a.data.order - b.data.order);
---

<header class="no-print fixed top-0 w-full z-50 bg-white/95 backdrop-blur-md shadow-[0_2px_15px_rgba(0,0,0,0.08)]">
  <div class="max-w-[1200px] mx-auto px-5">
    <nav class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="text-xl font-bold text-primary no-underline">
        Abdulwahed<span class="text-accent">.</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">
        {sorted.map((cv) => {
          const isActive = currentSlug === cv.data.slug;
          return (
            <a
              href={`/cv/${cv.data.slug}/`}
              class:list={[
                "relative text-[13px] font-medium px-3 py-2 rounded-lg transition-all",
                isActive
                  ? "text-primary bg-primary/5"
                  : "text-text-muted hover:text-text-primary hover:bg-surface-2",
              ]}
              title={cv.data.title}
            >
              {cv.data.short}
            </a>
          );
        })}
      </div>

      <!-- Mobile -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden text-text-muted hover:text-text-primary p-2 transition-colors"
        aria-label="Menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white border-t border-border">
    <div class="max-w-[1200px] mx-auto px-5 py-3 grid grid-cols-2 gap-1">
      {sorted.map((cv) => {
        const isActive = currentSlug === cv.data.slug;
        return (
          <a
            href={`/cv/${cv.data.slug}/`}
            class:list={[
              "text-sm font-medium px-3 py-2.5 rounded-lg transition-colors",
              isActive
                ? "text-primary bg-primary/5"
                : "text-text-muted hover:text-text-primary hover:bg-surface-2",
            ]}
          >
            {cv.data.short}
          </a>
        );
      })}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
</script>
